# ═══════════════════════════════════════════════════════════
# Switchboard 本機開發環境範本
# 用法:cp .env.example .env,填入數值後啟動 docker compose
# ═══════════════════════════════════════════════════════════

# ── 資料庫 ──────────────────────────────────────────
DATABASE_URL="postgresql://switchboard:switchboard_dev@localhost:5432/switchboard?schema=public"

# ── 認證 ───────────────────────────────────────────
# Session 簽章金鑰(64 字 hex = 32 bytes)
# 產生指令:openssl rand -hex 32
SESSION_SECRET="change-me-to-a-random-32-byte-hex-string"

# ── Telegram 帳號 session 加密 ─────────────────────
# ⚠️ 此金鑰遺失會導致所有 TG 帳號 session 無法解密,需重新綁定
# 產生指令:openssl rand -hex 32
TELEGRAM_SESSION_KEY="change-me-to-a-random-32-byte-hex-string"

# 說明:每個 Telegram 帳號的 API ID / API Hash 必須於帳號驗證 UI 個別填入
# (來源:https://my.telegram.org)。每帳號用自己申請的獨立 App,
# 避免任一帳號被封導致全體連鎖失效 — 不提供共用環境變數。
# 都不填 → mock 模式(驗證碼固定 12345),供本機開發測試用。

# ── 內部服務通訊 ────────────────────────────────────
# App 和 Bridge 之間的 shared secret(64 字 hex)
INTERNAL_SECRET="change-me-to-a-random-secret"
BRIDGE_PORT=3001
APP_INTERNAL_URL="http://localhost:1688"

# ── Telegram VoIP Gateway(真實內嵌通話)──────────
# 真實 TG 1:1 語音通話 = gateway(Node, 3002)+ media helper(Python, 3003)。
# 啟動方式:bash scripts/voip-call-stack.sh start(先跑 tools/voip-helper-provision-session.ts)
# 若未啟動 gateway,通話 API 會回 502/501,不影響文字訊息。
TELEGRAM_VOIP_GATEWAY_URL="http://localhost:3002"
TELEGRAM_VOIP_GATEWAY_SECRET="change-me-to-a-random-secret"
# 以下由 scripts/voip-call-stack.sh / ~/.switchboard/voip-helper.env 提供,通常不用放這裡:
# TELEGRAM_VOIP_HELPER_URL="http://127.0.0.1:3003"
# TELEGRAM_VOIP_ACCOUNT_ID=""            # helper 持有 session 的 CommunicationAccount id
# TELEGRAM_VOIP_ENABLE_REAL_CALLS="0"    # 真實通話總開關
# TELEGRAM_VOIP_ALLOW_ANY_PRIVATE_PEER="0" # 允許撥給任何私訊對象(Switchboard 端已有逐對話授權)
# TELEGRAM_VOIP_ICE_SERVERS='[]'         # 生產環境請加 TURN
# VOIP_HELPER_ENABLE_QA_LOOPBACK="0"     # helper 的 qa:loopback 媒體迴路測試模式

# ── Telegram Real Call QA Fixtures (do not commit real values) ──
# Only enable these in a controlled QA shell when an approved callee/caller is present.
TELEGRAM_API_ID=""
TELEGRAM_API_HASH=""
TELEGRAM_SESSION_STRING=""
SWITCHBOARD_BASE_URL="http://localhost:1688"
QA_ENABLE_REAL_TELEGRAM_CALL="0"
QA_APPROVED_CALLEE_PLATFORM_USER_ID=""
QA_APPROVED_CALLEE_GROUP_ID=""
QA_ENABLE_REAL_TELEGRAM_INCOMING_CALL="0"
QA_APPROVED_CALLER_PLATFORM_USER_ID=""
QA_CALLEE_CONFIRMED_RINGING="0"

# ── AI / LLM Provider ───────────────────────────────
# 直面對話 AI 語意分析與 AI 副駕。
# 未設定 LLM_PROVIDER / AI_PROVIDER 時，AI routes 會回 422。
LLM_PROVIDER="anthropic"
LLM_MODEL="claude-haiku-4-5"
ANTHROPIC_API_KEY=""

# 只供本機 production build + tunnel QA 測試。
# 不可在部署環境開啟；正式 production 請使用 token broker。

