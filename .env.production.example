# ═══════════════════════════════════════════════════════════
# Switchboard 生產環境設定範本
# ═══════════════════════════════════════════════════════════
# 步驟:
#   1. cp .env.production.example .env.production
#   2. bash scripts/deploy/generate-secrets.sh >> .env.production
#      (此腳本會自動填入所有隨機金鑰欄位)
#   3. chmod 600 .env.production
#
# ⚠️  .env.production 絕對不可 commit 到 git

# ── 資料庫 ──────────────────────────────────────────
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# ── App Port(外部 Nginx/Caddy 反向代理到此 port)────
APP_PORT=3000

# ── 認證 ───────────────────────────────────────────
# Session 簽章金鑰(64 字 hex = 32 bytes)
SESSION_SECRET=CHANGE_ME_64_HEX_CHARS

# ── Telegram 帳號 session 加密金鑰(64 字 hex)───────
# ⚠️ 此金鑰遺失會導致所有 TG 帳號 session 無法解密,需重新綁定
TELEGRAM_SESSION_KEY=CHANGE_ME_64_HEX_CHARS

# 說明:每個 Telegram 帳號的 API ID / API Hash 由使用者於
# 「帳號池 → 驗證」UI 個別填入(2026-04-14 會議決議,避免
# 一組共用憑證因封號而連鎖失效)。故**不需要**在 .env 設定
# TELEGRAM_API_ID / TELEGRAM_API_HASH。

# ── 內部服務通訊 ────────────────────────────────────
# App 和 Bridge 之間的 shared secret
INTERNAL_SECRET=CHANGE_ME_64_HEX_CHARS

# ── Telegram VoIP Gateway ───────────────────────────
# 指向外部 native daemon / WebRTC bridge，例如 http://telegram-voip-gateway:3002
# 若 secret 未另外設定，程式會 fallback 使用 INTERNAL_SECRET。
TELEGRAM_VOIP_GATEWAY_URL=
TELEGRAM_VOIP_GATEWAY_SECRET=

# ── AI / LLM Provider ───────────────────────────────
# 直面對話 AI 語意分析與 AI 副駕。
# 未設定 LLM_PROVIDER / AI_PROVIDER 時，AI routes 會回 422。
LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5
ANTHROPIC_API_KEY=

# Codex / ChatGPT subscription runtime provider
# Production 不應直接依賴個人 ~/.hermes/auth.json；請使用 secret manager 注入
# CODEX_ACCESS_TOKEN，或接內部 token broker。
#LLM_PROVIDER=codex
#LLM_MODEL=gpt-5.5
CODEX_BASE_URL=https://chatgpt.com/backend-api/codex
CODEX_ACCESS_TOKEN=
CODEX_TOKEN_BROKER_URL=
CODEX_TOKEN_BROKER_SECRET=
CODEX_AUTH_SOURCE=env
CODEX_ALLOW_HERMES_IN_PRODUCTION=false

# ── 日誌 ───────────────────────────────────────────
LOG_LEVEL=info

# ── Audit log 保留期限(天;bridge 每小時清理超出者)────
# 預設 90,若需合規更長可調(例如 365)
AUDIT_LOG_RETENTION_DAYS=90

# ── Bug 通報 ───────────────────────────────────────
# 若要啟用 Bug 通報功能，需建立 Telegram Bot 並設定以下變數：
# 1. 向 @BotFather 建立 bot，取得 BOT_TOKEN
# 2. 將 bot 加入異常通報群組
# 3. 取得群組的 chat_id（負數，可透過 @userinfobot 或發送訊息後查看）
#BUG_REPORT_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
#BUG_REPORT_CHAT_ID=-1001234567890

# ── Seed(首次部署)─────────────────────────────────
# 首次登入後建議立即在介面上更改密碼
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=CHANGE_ME_INITIAL_PW
SEED_CS_PASSWORD=CHANGE_ME_INITIAL_PW
