# Default — auto-detect text vs binary, normalize line endings to LF on commit
* text=auto eol=lf

# Source files — explicit LF
*.ts        text eol=lf
*.tsx       text eol=lf
*.mts       text eol=lf
*.cts       text eol=lf
*.js        text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.md        text eol=lf
*.sh        text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.html      text eol=lf
*.prisma    text eol=lf
*.sql       text eol=lf
*.env*      text eol=lf
.gitignore  text eol=lf

# Dockerfile, scripts, hooks must be LF (will fail in Linux container if CRLF)
Dockerfile*           text eol=lf
*.dockerfile          text eol=lf
.githooks/*           text eol=lf
scripts/**/*          text eol=lf

# Binary — never normalize
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tar       binary
*.pptx      binary
*.docx      binary
*.xlsx      binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
